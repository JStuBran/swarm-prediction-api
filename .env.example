# ─── LLM Configuration (required) ───────────────────────────────────────────
# OpenAI-compatible API key
LLM_API_KEY=your_llm_api_key_here

# LLM API base URL (default: OpenAI)
# For OpenAI: https://api.openai.com/v1
# For Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name
LLM_MODEL_NAME=gpt-4o-mini

# ─── x402 Payment Configuration (required for monetization) ─────────────────
# Your Base/Ethereum wallet address to receive USDC payments
WALLET_ADDRESS=0xYourWalletAddressHere

# ─── Deployment ──────────────────────────────────────────────────────────────
# Public URL (used in MCP manifest)
PUBLIC_URL=https://your-deployment-url.railway.app

# ─── Optional: MiroFish Full OASIS Integration ───────────────────────────────
# Required only if using full OASIS simulation engine (not lightweight mode)
# ZEP_API_KEY=your_zep_api_key_here
